generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id               Int            @id @default(autoincrement())
  username         String
  email            String         @unique
  created_at       DateTime       @default(now())
  emailVerified    DateTime?

  publications     Publication[]  @relation("PublicationCreatedBy")
  partners         Partner[]      @relation("PartnerCreatedBy")
  municipalities   Municipality[] @relation("MunicipalityCreatedBy")
  core_elements    CoreElement[]  @relation("CoreElementCreatedBy")
  mechanisms       Mechanism[]    @relation("MechanismCreatedBy")
  factors          Factor[]       @relation("FactorCreatedBy")

  invites_sent     Invite[]       @relation("InviteSentBy")
  accounts         Account[]      
  sessions         Session[]

  deletedAt        DateTime? 
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String

  provider          String
  providerAccountId String

  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "Account_userId_fkey")
}

model Invite {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  token       String    @unique

  invitedById Int?
  invitedBy   User?     @relation("InviteSentBy", fields: [invitedById], references: [id])

  expiresAt   DateTime
  usedAt      DateTime?

  createdAt   DateTime  @default(now())
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "Session_userId_fkey")
}

model Municipality {
  id            Int           @id @default(autoincrement())
  name          String
  description   String?       @db.Text
  image         String?


  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  
  created_by    Int
 
  core_elements CoreElement[]
  publications  Publication[]
  creator       User          @relation("MunicipalityCreatedBy", fields: [created_by], references: [id])

  @@index([created_by], map: "Municipality_created_by_fkey")
}

model CoreElement {
  id              Int          @id @default(autoincrement())
  municipality_id Int
  title           String
  slug            String       @unique
  
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  
  created_by      Int
  creator         User         @relation("CoreElementCreatedBy", fields: [created_by], references: [id])
 
  municipality    Municipality @relation(fields: [municipality_id], references: [id], onDelete: Cascade)
  factors         Factor[]
  mechanisms      Mechanism[]

  @@index([created_by], map: "CoreElement_created_by_fkey")
  @@index([municipality_id], map: "CoreElement_municipality_id_fkey")
}

model Mechanism {
  id              Int         @id @default(autoincrement())
  core_element_id Int
  text            String      @db.Text
  
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt
  
  created_by      Int
  
  core_element CoreElement @relation(fields: [core_element_id], references: [id], onDelete: Cascade)
  creator         User        @relation("MechanismCreatedBy", fields: [created_by], references: [id])

  @@index([core_element_id], map: "Mechanism_core_element_id_fkey")
  @@index([created_by], map: "Mechanism_created_by_fkey")
}

model Factor {
  id              Int         @id @default(autoincrement())
  core_element_id Int
  text            String      @db.Text
  type            FactorType
  
  created_at      DateTime    @default(now())
  
  created_by      Int
  updated_at      DateTime    @updatedAt
  
  core_element CoreElement @relation(fields: [core_element_id], references: [id], onDelete: Cascade)
  creator         User        @relation("FactorCreatedBy", fields: [created_by], references: [id])

  @@index([core_element_id], map: "Factor_core_element_id_fkey")
  @@index([created_by], map: "Factor_created_by_fkey")
}

enum FactorType {
  plus
  min
}

model Publication {
  id            Int           @id @default(autoincrement())
  title         String
  author        String
  description   String        @db.Text
  url           String?
  published_at  DateTime?

  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  
  created_by    Int
  creator       User          @relation("PublicationCreatedBy", fields: [created_by], references: [id])

  municipality_id Int?
  municipality    Municipality? @relation(fields: [municipality_id], references: [id])

  @@index([created_by], map: "Publication_created_by_fkey")
  @@index([municipality_id], map: "Publication_municipality_id_fkey")
}

model Partner {
  id             Int          @id @default(autoincrement())
  name           String
  logo           String
  website        String
  description    String       @db.Text
  partnerInfo    String       @db.Text
  researchRole   String       @db.Text

  image1         String?
  image2         String?
  image3         String?

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  created_by    Int
  creator       User      @relation("PartnerCreatedBy", fields: [created_by], references: [id])
}