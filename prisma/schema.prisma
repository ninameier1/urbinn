// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  admin
}

enum FactorType {
  plus
  min
}

model User {
  id               Int            @id @default(autoincrement())
  username         String
  email            String         @unique
  password_hash    String
  role             Role           @default(admin)
  created_at       DateTime       @default(now())

  municipalities   Municipality[] @relation("MunicipalityCreatedBy")
  core_elements    CoreElement[]  @relation("CoreElementCreatedBy")
  mechanisms       Mechanism[]    @relation("MechanismCreatedBy")
  factors          Factor[]       @relation("FactorCreatedBy")
}

model Municipality {
  id            Int           @id @default(autoincrement())
  name          String
  image         String?
  created_at    DateTime      @default(now())
  created_by    Int
  creator       User          @relation("MunicipalityCreatedBy", fields: [created_by], references: [id])

  core_elements CoreElement[]
}

model CoreElement {
  id              Int          @id @default(autoincrement())
  municipality_id Int
  title           String
  slug            String       @unique
  created_at      DateTime     @default(now())
  created_by      Int
  municipality    Municipality @relation(fields: [municipality_id], references: [id])
  creator         User         @relation("CoreElementCreatedBy", fields: [created_by], references: [id])

  mechanisms      Mechanism[]
  factors         Factor[]
}

model Mechanism {
  id              Int         @id @default(autoincrement())
  core_element_id Int
  label           String
  text            String      @db.Text
  created_at      DateTime    @default(now())
  created_by      Int
  core_element    CoreElement @relation(fields: [core_element_id], references: [id])
  creator         User        @relation("MechanismCreatedBy", fields: [created_by], references: [id])
}

model Factor {
  id              Int         @id @default(autoincrement())
  core_element_id Int
  label           String
  text            String      @db.Text
  type            FactorType
  created_at      DateTime    @default(now())
  created_by      Int
  core_element    CoreElement @relation(fields: [core_element_id], references: [id])
  creator         User        @relation("FactorCreatedBy", fields: [created_by], references: [id])
}